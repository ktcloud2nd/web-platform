PORT=4000

# Local PostgreSQL example
# Replace YOUR_POSTGRES_PASSWORD with the password you set in pgAdmin/PostgreSQL.
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/web_platform

# Deploy example
# DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@TERRAFORM_CREATED_DB_ENDPOINT:5432/web_platform

# QuickSight embedding
AWS_REGION=ap-northeast-2
QUICKSIGHT_AWS_ACCOUNT_ID=123456789012
QUICKSIGHT_NAMESPACE=default
QUICKSIGHT_ALLOWED_DOMAINS=http://localhost:5173
QUICKSIGHT_SESSION_LIFETIME_MINUTES=60
QUICKSIGHT_ANOMALY_DASHBOARD_ID=5c7fd390-41aa-40b7-8a8f-bd0fe612113b
QUICKSIGHT_VEHICLE_DASHBOARD_ID=your-vehicle-dashboard-id
QUICKSIGHT_REGISTERED_USER_ARN=arn:aws:quicksight:ap-northeast-2:123456789012:user/default/your-registered-user
QUICKSIGHT_ANOMALY_SHEET_ID=your-sheet-id
QUICKSIGHT_ANOMALY_VISUAL_TOTAL_ANOMALIES=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_AFFECTED_VEHICLES=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_SUDDEN_BRAKE=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_SUDDEN_ACCELERATION=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_LOW_FUEL=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_GPS_ISSUE=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_DATA_BURST=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_MISSING_DATA=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_RATIO=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_TABLE=your-visual-id
QUICKSIGHT_ANOMALY_VISUAL_TIMELINE=your-visual-id
