# Place this file next to docker-compose.deployment.yml in apps/web-platform.
# Copy it to deploy.env before starting the deployment compose file.
# Use it both as:
# - runtime env for login/user/operator backend containers
# - compose substitution file for image names and exposed ports
# Example:
# docker compose --env-file deploy.env -f docker-compose.deployment.yml up -d
#
# Frontend redirect URLs below should point to each separated frontend entrypoint.
# When you build images, pass the same values as Docker build args so login -> user/operator
# redirection works even when the frontends are deployed on different hosts or ports.
#
# DATABASE_URL should point to the PostgreSQL/RDS endpoint created by Terraform.
# Replace the values below with the actual RDS information:
# - DB_USER: Terraform-created PostgreSQL username
# - DB_PASSWORD: Terraform-created PostgreSQL password
# - TERRAFORM_CREATED_DB_ENDPOINT: RDS endpoint hostname
# - 5432: PostgreSQL port
# - vehicletemp: target database name
# Example:
# DATABASE_URL=postgresql://app_user:app_password@my-rds-instance.abcdefg.ap-northeast-2.rds.amazonaws.com:5432/vehicletemp

# Separate image build examples:
# docker build -f backend/Dockerfile --build-arg APP_TARGET=login -t your-registry/web-platform-login-backend:latest ./backend
# docker build -f backend/Dockerfile --build-arg APP_TARGET=user -t your-registry/web-platform-user-backend:latest ./backend
# docker build -f backend/Dockerfile --build-arg APP_TARGET=operator -t your-registry/web-platform-operator-backend:latest ./backend
# docker build -f frontend/Dockerfile --build-arg APP_TARGET=login --build-arg NGINX_CONF=nginx.login.conf --build-arg VITE_LOGIN_APP_URL=http://LOGIN_HOST/login --build-arg VITE_USER_APP_URL=http://USER_HOST/user/dashboard --build-arg VITE_OPERATOR_APP_URL=http://OPERATOR_HOST/operator/infra-service -t your-registry/web-platform-login-frontend:latest ./frontend
# docker build -f frontend/Dockerfile --build-arg APP_TARGET=user --build-arg NGINX_CONF=nginx.user.conf --build-arg VITE_LOGIN_APP_URL=http://LOGIN_HOST/login --build-arg VITE_USER_APP_URL=http://USER_HOST/user/dashboard --build-arg VITE_OPERATOR_APP_URL=http://OPERATOR_HOST/operator/infra-service -t your-registry/web-platform-user-frontend:latest ./frontend
# docker build -f frontend/Dockerfile --build-arg APP_TARGET=operator --build-arg NGINX_CONF=nginx.operator.conf --build-arg VITE_LOGIN_APP_URL=http://LOGIN_HOST/login --build-arg VITE_USER_APP_URL=http://USER_HOST/user/dashboard --build-arg VITE_OPERATOR_APP_URL=http://OPERATOR_HOST/operator/infra-service -t your-registry/web-platform-operator-frontend:latest ./frontend

LOGIN_BACKEND_IMAGE=your-registry/web-platform-login-backend:latest
USER_BACKEND_IMAGE=your-registry/web-platform-user-backend:latest
OPERATOR_BACKEND_IMAGE=your-registry/web-platform-operator-backend:latest
LOGIN_FRONTEND_IMAGE=your-registry/web-platform-login-frontend:latest
USER_FRONTEND_IMAGE=your-registry/web-platform-user-frontend:latest
OPERATOR_FRONTEND_IMAGE=your-registry/web-platform-operator-frontend:latest

LOGIN_FRONTEND_PORT=8080
USER_FRONTEND_PORT=8081
OPERATOR_FRONTEND_PORT=8082

LOGIN_APP_URL=http://localhost:8080/login
USER_APP_URL=http://localhost:8081/user/dashboard
OPERATOR_APP_URL=http://localhost:8082/operator/infra-service

DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@TERRAFORM_CREATED_DB_ENDPOINT:5432/vehicletemp
PORT=4000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:8082

# TODO(RDS): when switching from local DB to AWS RDS, keep the DB private and let only
# backend workloads connect to it through security-group-to-security-group rules.
# Expected Terraform ownership:
# - infra/aws/terraform/data: RDS, DB subnet group, parameter group
# - infra/aws/terraform/compute: backend workload SG / task definition / instance role
# Recommended production shape:
# - login-backend / user-backend / operator-backend -> private RDS endpoint
# - frontend containers must never connect directly to RDS
# - replace TERRAFORM_CREATED_DB_ENDPOINT with the real RDS endpoint output
# Uncomment these only after Terraform/RDS outputs are wired and you intentionally stop using
# the single DATABASE_URL form above.
# DB_HOST=TERRAFORM_CREATED_DB_ENDPOINT
# DB_PORT=5432
# DB_NAME=vehicletemp
# DB_USER=DB_USER
# DB_PASSWORD=DB_PASSWORD

# QuickSight / AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN
QUICKSIGHT_AWS_ACCOUNT_ID=578272380060
QUICKSIGHT_NAMESPACE=default
QUICKSIGHT_REGISTERED_USER_ARN=arn:aws:quicksight:ap-northeast-2:578272380060:user/default/YOUR_QUICKSIGHT_USERNAME
QUICKSIGHT_ALLOWED_DOMAINS=http://YOUR_DOMAIN
QUICKSIGHT_SESSION_LIFETIME_MINUTES=60

# QuickSight dashboards
QUICKSIGHT_ANOMALY_DASHBOARD_ID=YOUR_ANOMALY_DASHBOARD_ID
QUICKSIGHT_VEHICLE_DASHBOARD_ID=YOUR_VEHICLE_DASHBOARD_ID

# TODO(Grafana): keep this commented out until local testing is done.
# If we move from QuickSight or add operator-only Grafana embedding later, the safer path is:
# - self-hosted Grafana behind ALB for iframe embedding
# - operator frontend only should receive/embed the Grafana URL
# - login/user frontend should not expose Grafana directly
# - if Amazon Managed Grafana is chosen instead, SSO/sharing rules must be reviewed separately
