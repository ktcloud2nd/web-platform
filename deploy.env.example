# Place this file next to docker-compose.deployment.yml in apps/web-platform.
# Copy it to deploy.env before starting the deployment compose file.
# This single env file is shared by:
# - backend
# - frontend
# DATABASE_URL should point to the PostgreSQL/RDS endpoint created by Terraform.
# Replace the values below with the actual RDS information:
# - DB_USER: Terraform-created PostgreSQL username
# - DB_PASSWORD: Terraform-created PostgreSQL password
# - TERRAFORM_CREATED_DB_ENDPOINT: RDS endpoint hostname
# - 5432: PostgreSQL port
# - vehicletemp: target database name
# Example:
# DATABASE_URL=postgresql://app_user:app_password@my-rds-instance.abcdefg.ap-northeast-2.rds.amazonaws.com:5432/vehicletemp

# Separate image build examples:
# docker build -f backend/Dockerfile -t your-registry/web-platform-backend:latest ./backend
# docker build -f frontend/Dockerfile -t your-registry/web-platform-frontend:latest ./frontend

DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@TERRAFORM_CREATED_DB_ENDPOINT:5432/vehicletemp
PORT=4000

# QuickSight / AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN
QUICKSIGHT_AWS_ACCOUNT_ID=578272380060
QUICKSIGHT_NAMESPACE=default
QUICKSIGHT_REGISTERED_USER_ARN=arn:aws:quicksight:ap-northeast-2:578272380060:user/default/YOUR_QUICKSIGHT_USERNAME
QUICKSIGHT_ALLOWED_DOMAINS=http://YOUR_DOMAIN
QUICKSIGHT_SESSION_LIFETIME_MINUTES=60

# QuickSight dashboards
QUICKSIGHT_ANOMALY_DASHBOARD_ID=YOUR_ANOMALY_DASHBOARD_ID
QUICKSIGHT_VEHICLE_DASHBOARD_ID=YOUR_VEHICLE_DASHBOARD_ID
